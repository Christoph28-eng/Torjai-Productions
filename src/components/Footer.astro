---
const year = new Date().getFullYear();

const columns = [
  {
    title: 'INDEX',
    links: [
      { label: 'PROJECTS', href: '/projects' },
      { label: 'SERVICES', href: '/services' },
      { label: 'ABOUT', href: '/about' },
      { label: 'CONTACT', href: '/contact' },
    ],
  },
  {
    title: 'SOCIAL',
    // TODO: înlocuiește # cu linkurile reale
    links: [
      { label: 'INSTAGRAM', href: '#' },
      { label: 'VIMEO', href: '#' },
      { label: 'LINKEDIN', href: '#' },
    ],
  },
  {
    title: 'LEGAL',
    links: [
      { label: 'IMPRINT', href: '/imprint' },
      { label: 'PRIVACY', href: '/privacy' },
      { label: 'TERMS', href: '/terms' },
    ],
  },
];
---

<footer class="w-full border-t border-studio-grey bg-surface-container-lowest pb-8 pt-16">
  <div
    class="mx-auto mb-16 grid max-w-container-max grid-cols-1 gap-gutter px-margin-mobile md:grid-cols-12 md:px-margin-desktop"
  >
    <div class="md:col-span-4">
      <div
        class="mb-4 font-headline-lg text-headline-lg tracking-tighter text-studio-grey opacity-20"
      >
        TORJAI
      </div>
      <p class="max-w-xs font-label-technical text-label-technical text-outline">
        HIGH-END CINEMATOGRAPHY &amp; INDUSTRIAL FILM PRODUCTION BASED IN BERLIN.
      </p>
    </div>

    <div class="flex flex-wrap gap-12 pt-8 md:col-span-8 md:justify-end md:gap-24 md:pt-0">
      {
        columns.map((col) => (
          <div class="flex flex-col gap-4">
            <span class="mb-2 font-label-technical text-label-technical text-technical-amber">
              {col.title}
            </span>
            {col.links.map((link) => (
              <a
                href={link.href}
                class="font-label-technical text-label-technical text-outline transition-all duration-200 hover:translate-x-1 hover:text-technical-amber"
              >
                {link.label}
              </a>
            ))}
          </div>
        ))
      }
    </div>
  </div>

  <div
    class="mx-auto flex max-w-container-max flex-col items-center justify-between gap-4 border-t border-studio-grey px-margin-mobile pt-8 md:flex-row md:px-margin-desktop"
  >
    <span class="font-label-technical text-label-technical text-outline">
      &copy;{year} TORJAI PRODUCTIONS BERLIN. ALL RIGHTS RESERVED.
    </span>
    <div
      class="flex items-center gap-2 font-label-technical text-label-technical text-outline"
    >
      <span class="inline-block h-2 w-2 rounded-full bg-status-active"></span> SYSTEM ONLINE
    </div>
  </div>
</footer>
