---
// Secțiune de testimoniale — structură identică cu design-ul Stitch,
// text adaptat unei case de producție foto/video.
// Accent: technical-amber (galbenul de brand Torjai).

const big = {
  metric: '8X',
  metricLabel: 'Audience engagement at launch',
  quote:
    'Torjai turned our product launch into a film we were proud to put our name on. Every frame felt intentional — the lighting, the grade, the rhythm of the edit. Launch-day engagement was eight times our previous campaign.',
  name: 'Mara Vogel',
  role: 'Brand Director, Belstaff',
  initials: 'MV',
};

const medium = {
  metric: '2.4M',
  metricLabel: 'Views in 30 days',
  quote:
    'From concept to final grade, the team owned the entire brand film. The industrial aesthetic was exactly the language we needed.',
  name: 'Jonas Keller',
  role: 'Head of Marketing, STYRKR',
  initials: 'JK',
};

const small = {
  quote:
    'Their post-production elevated our product films to a cinematic level — color and sound design were flawless.',
  name: 'Elena Roth',
  role: 'Creative Lead, AIM',
  initials: 'ER',
};

const smallDark = {
  quote:
    'Fast turnaround, obsessive attention to detail, and a final cut that felt genuinely premium.',
  name: 'Daniel Fischer',
  role: 'Founder, Aether',
  initials: 'DF',
};
---

<section class="bg-white px-margin-mobile py-32 text-deep-charcoal md:px-margin-desktop">
  <div class="mx-auto max-w-container-max">
    <!-- Header -->
    <div class="mb-16 text-center">
      <div class="mb-4 flex items-center justify-center gap-1">
        <span class="flex items-center font-label-technical text-xs uppercase tracking-tighter text-technical-amber">
          <span class="mr-1">⌞</span>Testimonials<span class="ml-1">⌝</span>
        </span>
      </div>
      <h2 class="mb-2 font-headline-md text-4xl uppercase tracking-tighter text-deep-charcoal md:text-5xl">
        Results that speak volume
      </h2>
      <p class="font-headline-lg text-4xl uppercase tracking-tighter text-[#8e8e8e] md:text-5xl">
        Trusted by leading brands
      </p>
      <p class="mt-6 font-body-md text-on-primary-container">
        Find out why brands and studios choose Torjai.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="mb-4 grid grid-cols-1 gap-6 md:grid-cols-12">
      <!-- Card 1: Large Left (dark) -->
      <div
        class="flex min-h-[500px] flex-col justify-between rounded-[2.5rem] bg-deep-charcoal p-12 shadow-sm md:col-span-7"
      >
        <div>
          <h3 class="mb-2 font-headline-lg text-8xl text-white md:text-9xl">{big.metric}</h3>
          <p class="mb-12 font-label-button text-xl uppercase text-white">{big.metricLabel}</p>
          <div class="mb-8">
            <span class="font-serif text-3xl text-technical-amber">&ldquo;</span>
            <p class="mt-2 font-body-lg text-lg leading-relaxed text-tertiary">{big.quote}</p>
          </div>
        </div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center overflow-hidden rounded-full bg-studio-grey">
              <span class="font-label-button text-sm text-white">{big.initials}</span>
            </div>
            <div>
              <p class="font-label-button text-sm uppercase text-white">{big.name}</p>
              <p class="font-label-technical text-[10px] uppercase text-tertiary">{big.role}</p>
            </div>
          </div>
          <div class="h-8 w-8 text-white/40">
            <span class="material-symbols-outlined" aria-hidden="true">album</span>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-6 md:col-span-5">
        <!-- Card 2: Medium Top Right (light) -->
        <div class="flex flex-col rounded-[2.5rem] bg-[#f8f8f8] p-8 shadow-sm">
          <h3 class="mb-1 font-headline-md text-3xl">
            {medium.metric}
            <span class="font-body-md text-lg font-normal normal-case">{medium.metricLabel}</span>
          </h3>
          <div class="mb-6 mt-6">
            <span class="font-serif text-2xl text-technical-amber">&ldquo;</span>
            <p class="font-body-md text-sm leading-relaxed text-on-primary-container">{medium.quote}</p>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center overflow-hidden rounded-full bg-slate-200">
                <span class="font-label-button text-xs text-deep-charcoal">{medium.initials}</span>
              </div>
              <div>
                <p class="font-label-button text-xs uppercase">{medium.name}</p>
                <p class="font-label-technical text-[9px] uppercase text-on-primary-container">{medium.role}</p>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <!-- Card 3: Small (light) -->
          <div class="flex flex-col justify-between rounded-[2.5rem] bg-[#f8f8f8] p-8 shadow-sm">
            <div class="mb-6">
              <span class="font-serif text-2xl text-technical-amber">&ldquo;</span>
              <p class="font-body-md text-sm leading-relaxed text-on-primary-container">{small.quote}</p>
            </div>
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center overflow-hidden rounded-full bg-slate-200">
                <span class="font-label-button text-xs text-deep-charcoal">{small.initials}</span>
              </div>
              <div>
                <p class="font-label-button text-xs uppercase">{small.name}</p>
                <p class="font-label-technical text-[9px] uppercase text-on-primary-container">{small.role}</p>
              </div>
            </div>
          </div>

          <!-- Card 4: Small (dark) -->
          <div class="flex flex-col justify-between rounded-[2.5rem] bg-deep-charcoal p-8 shadow-lg">
            <div class="mb-6 text-white">
              <span class="font-serif text-2xl text-technical-amber">&ldquo;</span>
              <p class="mt-2 font-body-md text-sm leading-relaxed text-tertiary">{smallDark.quote}</p>
            </div>
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center overflow-hidden rounded-full bg-studio-grey">
                <span class="font-label-button text-xs text-white">{smallDark.initials}</span>
              </div>
              <div class="text-white">
                <p class="font-label-button text-xs uppercase">{smallDark.name}</p>
                <p class="font-label-technical text-[9px] uppercase text-tertiary">{smallDark.role}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
