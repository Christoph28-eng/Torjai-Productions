---
// Lightbox.astro — popup pentru galeria de proiect.
// Click pe o poză/clip → se deschide pe tot ecranul, cu navigare prin
// săgeți / tastatură (← → Esc) / swipe pe telefon. Clipurile se redau fie ca
// video local (MP4, data-video-src), fie ca player embed (Vimeo/YouTube, data-embed).
// Citește elementele cu [data-lb-item] din #gallery-grid.
---

<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Project media viewer"
  aria-hidden="true"
>
  <!-- Închidere -->
  <button
    type="button"
    data-lb-close
    aria-label="Close"
    class="absolute right-4 top-4 z-20 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20 md:right-6 md:top-6"
  >
    <span class="material-symbols-outlined text-3xl" aria-hidden="true">close</span>
  </button>

  <!-- Zoom (apare doar la poze) -->
  <button
    type="button"
    data-lb-zoom
    aria-label="Zoom photo"
    class="absolute left-4 top-4 z-20 hidden h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20 md:left-6 md:top-6"
  >
    <span class="material-symbols-outlined text-3xl" aria-hidden="true">zoom_in</span>
  </button>

  <!-- Contor -->
  <div
    id="lb-counter"
    class="absolute left-1/2 top-6 z-20 -translate-x-1/2 font-label-technical text-label-technical uppercase tracking-widest text-white/70"
  >
  </div>

  <!-- Săgeată stânga -->
  <button
    type="button"
    data-lb-prev
    aria-label="Previous"
    class="absolute left-3 top-1/2 z-20 flex h-14 w-14 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20 md:left-6"
  >
    <span class="material-symbols-outlined text-4xl" aria-hidden="true">chevron_left</span>
  </button>

  <!-- Săgeată dreapta -->
  <button
    type="button"
    data-lb-next
    aria-label="Next"
    class="absolute right-3 top-1/2 z-20 flex h-14 w-14 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20 md:right-6"
  >
    <span class="material-symbols-outlined text-4xl" aria-hidden="true">chevron_right</span>
  </button>

  <!-- Conținut (poză sau player) -->
  <div id="lb-stage" class="flex max-h-[88vh] w-full max-w-[92vw] items-center justify-center overflow-hidden rounded-[16px] px-2"></div>
</div>

<script>
  type LBItem = { type: 'photo' | 'video'; full: string; embed: string; videoSrc: string; muted: boolean; alt: string };

  const lb = document.getElementById('lightbox');
  const stage = document.getElementById('lb-stage');
  const counter = document.getElementById('lb-counter');
  const grid = document.getElementById('gallery-grid');
  if (lb && stage && counter && grid) {
    let items: LBItem[] = [];
    let index = 0;

    let lastFocused: HTMLElement | null = null;

    // ── Zoom (doar pentru poze) ──────────────────────────────────────────
    const zoomBtn = lb.querySelector('[data-lb-zoom]') as HTMLButtonElement | null;
    const ZOOM = 2.2;
    const TAP = 6; // px: sub atât = click (toggle zoom), peste = pan
    let zoom = 1;
    let panX = 0;
    let panY = 0;
    let pointerActive = false;
    let capturedId = -1;
    let lastX = 0;
    let lastY = 0;
    let moved = 0;

    const currentImg = () => stage.querySelector('img') as HTMLImageElement | null;

    // Dimensiunea REALĂ afișată a pozei (object-contain). La zoom 1 cutia <img> are deja
    // raportul imaginii, dar o calculăm explicit ca să fim corecți și dacă apare letterbox.
    // Întoarce null cât timp poza nu e încărcată / fără layout (clientWidth/naturalWidth 0).
    function displayedSize(img: HTMLImageElement) {
      const boxW = img.clientWidth, boxH = img.clientHeight;
      const nw = img.naturalWidth, nh = img.naturalHeight;
      if (!boxW || !boxH || !nw || !nh) return null;
      const ar = nw / nh;
      return boxW / boxH > ar ? { w: boxH * ar, h: boxH } : { w: boxW, h: boxW / ar };
    }

    function applyTransform() {
      const img = currentImg();
      if (!img) return;
      const d = displayedSize(img);
      if (!d) { img.style.transform = `scale(${zoom})`; return; } // neîncărcată: doar scalează
      // Limitează panoramarea la marginile REALE ale pozei.
      const maxX = (d.w * (zoom - 1)) / 2;
      const maxY = (d.h * (zoom - 1)) / 2;
      panX = Math.max(-maxX, Math.min(maxX, panX));
      panY = Math.max(-maxY, Math.min(maxY, panY));
      img.style.transform = `translate(${panX}px, ${panY}px) scale(${zoom})`;
    }

    function releaseCapture() {
      if (capturedId !== -1) {
        try { stage.releasePointerCapture(capturedId); } catch {}
        capturedId = -1;
      }
    }

    // Mărește/micșorează. Cu focusX/Y, zoom-in se centrează pe punctul atins
    // (zoom-to-cursor); altfel pe centrul pozei.
    function applyZoomState(on: boolean, focusX?: number, focusY?: number) {
      zoom = on ? ZOOM : 1;
      if (!on) {
        panX = 0;
        panY = 0;
      } else if (typeof focusX === 'number' && typeof focusY === 'number') {
        const img = currentImg();
        if (img) {
          const r = img.getBoundingClientRect();
          panX = (focusX - (r.left + r.width / 2)) * (1 - ZOOM);
          panY = (focusY - (r.top + r.height / 2)) * (1 - ZOOM);
        }
      }
      const img = currentImg();
      if (img) {
        img.style.transition = 'transform 0.2s ease';
        img.style.cursor = on ? 'grab' : 'zoom-in';
        img.style.willChange = on ? 'transform' : 'auto';
      }
      applyTransform();
      if (zoomBtn) {
        const zi = zoomBtn.querySelector('span');
        if (zi) zi.textContent = on ? 'zoom_out' : 'zoom_in';
        zoomBtn.setAttribute('aria-pressed', on ? 'true' : 'false');
      }
    }

    function resetZoom() {
      zoom = 1;
      panX = 0;
      panY = 0;
      pointerActive = false;
      moved = 0;
      releaseCapture();
    }

    const escapeAttr = (s: string) => s.replace(/"/g, '&quot;');

    function render() {
      const it = items[index];
      if (!it) return;
      resetZoom();
      if (it.type === 'video' && it.videoSrc && it.muted) {
        // Clip mut blocat (footage BTS): pornește mut, în buclă, FĂRĂ controale →
        // nu există control de volum și sunetul nu poate fi modificat.
        stage.innerHTML =
          `<video src="${it.videoSrc}" autoplay muted loop playsinline disablepictureinpicture ` +
          `controlslist="nodownload noremoteplayback" ` +
          `class="max-h-[88vh] max-w-full rounded-[16px] bg-black"></video>`;
        const v = stage.querySelector('video');
        if (v) {
          v.addEventListener('contextmenu', (e) => e.preventDefault()); // fără „Show controls"
          v.addEventListener('volumechange', () => { v.muted = true; }); // re-mut dacă e forțat
        }
      } else if (it.type === 'video' && it.videoSrc) {
        stage.innerHTML =
          `<video src="${it.videoSrc}" controls autoplay playsinline ` +
          `class="max-h-[88vh] max-w-full rounded-[16px] bg-black"></video>`;
      } else if (it.type === 'video' && it.embed && it.embed.includes('instagram.com')) {
        // Card oficial Instagram (cu caption) — format portret: lățime fixă, înălțime
        // mare. Fundalul cardului e alb, deci wrapper-ul alb maschează spațiul gol.
        stage.innerHTML =
          `<div class="h-[88vh] w-full max-w-[400px] overflow-hidden rounded-[16px] bg-white">` +
          `<iframe class="h-full w-full border-0" src="${it.embed}" ` +
          `title="${escapeAttr(it.alt)}" scrolling="yes" allowtransparency="true" ` +
          `allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"></iframe></div>`;
      } else if (it.type === 'video' && it.embed) {
        stage.innerHTML =
          `<div class="relative aspect-video w-full max-w-[1100px]">` +
          `<iframe class="absolute inset-0 h-full w-full rounded-[20px]" src="${it.embed}" ` +
          `title="${escapeAttr(it.alt)}" frameborder="0" ` +
          `allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe></div>`;
      } else {
        // draggable=false + select-none → fără drag nativ de imagine care ar fura pan-ul.
        // [touch-action:none] → pan fiabil pe touch. origin-center → zoom previzibil.
        stage.innerHTML =
          `<img src="${it.full}" alt="${escapeAttr(it.alt)}" draggable="false" ` +
          `class="max-h-[88vh] max-w-full select-none origin-center rounded-[16px] object-contain [touch-action:none] [-webkit-user-drag:none]" />`;
      }
      // Butonul de zoom apare DOAR la poze (nu la video / embed-uri).
      const isPhoto = it.type === 'photo';
      if (zoomBtn) {
        zoomBtn.classList.toggle('hidden', !isPhoto);
        zoomBtn.classList.toggle('flex', isPhoto);
        const zi = zoomBtn.querySelector('span');
        if (zi) zi.textContent = 'zoom_in';
        zoomBtn.setAttribute('aria-label', 'Zoom photo');
        zoomBtn.setAttribute('aria-pressed', 'false');
        zoomBtn.setAttribute('aria-hidden', String(!isPhoto));
        zoomBtn.tabIndex = isPhoto ? 0 : -1;
      }
      const pimg = currentImg();
      if (isPhoto && pimg) {
        pimg.style.cursor = 'zoom-in';
        // Re-aplică transform-ul după ce poza s-a încărcat (clamp corect, nu blocat la 0).
        pimg.addEventListener('load', applyTransform);
      }

      counter.textContent = `${index + 1} / ${items.length}`;
    }

    function open(list: LBItem[], start: number) {
      lastFocused = document.activeElement as HTMLElement | null;
      items = list;
      index = start;
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      lb.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      render();
      (lb.querySelector('[data-lb-close]') as HTMLElement | null)?.focus(); // intră focusul în modal
    }

    function close() {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      lb.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      stage.innerHTML = ''; // oprește videoul
      resetZoom();
      lastFocused?.focus(); // readu focusul la elementul din care s-a deschis
    }

    function go(delta: number) {
      if (!items.length) return;
      index = (index + delta + items.length) % items.length;
      render();
    }

    // Deschidere la click pe un element din grilă — doar cele vizibile (respectă filtrul activ).
    grid.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('[data-lb-item]') as HTMLElement | null;
      if (!btn) return;
      const visible = Array.from(grid.querySelectorAll<HTMLElement>('[data-lb-item]')).filter(
        (el) => el.offsetParent !== null,
      );
      const list: LBItem[] = visible.map((el) => ({
        type: (el.dataset.type as 'photo' | 'video') || 'photo',
        full: el.dataset.full || '',
        embed: el.dataset.embed || '',
        videoSrc: el.dataset.videoSrc || '',
        muted: el.dataset.muted === 'true',
        alt: el.dataset.alt || '',
      }));
      const start = visible.indexOf(btn);
      open(list, start < 0 ? 0 : start);
    });

    lb.querySelector('[data-lb-close]')?.addEventListener('click', close);
    lb.querySelector('[data-lb-prev]')?.addEventListener('click', () => go(-1));
    lb.querySelector('[data-lb-next]')?.addEventListener('click', () => go(1));
    lb.addEventListener('click', (e) => {
      if (e.target === lb) close(); // click pe fundal
    });

    // Buton zoom dedicat (toggle 1× ↔ 2.2×, centrat) — vizibil doar la poze.
    zoomBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      applyZoomState(zoom === 1);
    });

    // Interacțiune pe poză: tap = toggle zoom (zoom-in pe punctul atins),
    // drag = pan cât timp e mărită. Gestul trebuie să înceapă pe <img>.
    stage.addEventListener('pointerdown', (e) => {
      if (!(e.target instanceof HTMLImageElement)) return;
      pointerActive = true;
      moved = 0;
      lastX = e.clientX;
      lastY = e.clientY;
      if (zoom > 1) {
        const img = currentImg();
        if (img) { img.style.transition = 'none'; img.style.cursor = 'grabbing'; }
        try { stage.setPointerCapture(e.pointerId); capturedId = e.pointerId; } catch {}
      }
    });
    stage.addEventListener('pointermove', (e) => {
      if (!pointerActive) return;
      const dx = e.clientX - lastX;
      const dy = e.clientY - lastY;
      moved += Math.abs(dx) + Math.abs(dy);
      lastX = e.clientX;
      lastY = e.clientY;
      if (zoom > 1) {
        panX += dx;
        panY += dy;
        applyTransform();
      }
    });
    stage.addEventListener('pointerup', (e) => {
      if (!pointerActive) return;
      pointerActive = false;
      releaseCapture();
      if (moved < TAP) {
        // tap pe poză → comută zoom (in pe punctul atins / out)
        if (zoom === 1) applyZoomState(true, e.clientX, e.clientY);
        else applyZoomState(false);
      } else {
        const img = currentImg();
        if (img) img.style.cursor = 'grab';
      }
    });
    stage.addEventListener('pointercancel', () => {
      pointerActive = false;
      releaseCapture();
      const img = currentImg();
      if (img && zoom > 1) img.style.cursor = 'grab';
    });

    // Blochează drag-ul nativ de imagine (ghost) care ar fura gestul de pan.
    stage.addEventListener('dragstart', (e) => e.preventDefault());

    document.addEventListener('keydown', (e) => {
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') { close(); return; }
      // Săgețile navighează doar la 1× (la fel ca swipe-ul) ca să nu reseteze zoom-ul.
      if (e.key === 'ArrowLeft' && zoom === 1) go(-1);
      else if (e.key === 'ArrowRight' && zoom === 1) go(1);
      else if (e.key === 'Tab') {
        // Focus trap: ține focusul pe controalele modalului.
        const f = Array.from(lb.querySelectorAll<HTMLElement>('button')).filter((el) => el.offsetParent !== null);
        if (!f.length) return;
        const first = f[0];
        const last = f[f.length - 1];
        const active = document.activeElement as HTMLElement | null;
        if (e.shiftKey && active === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && active === last) { e.preventDefault(); first.focus(); }
        else if (!active || !f.includes(active)) { e.preventDefault(); first.focus(); }
      }
    });

    // Swipe pe touch
    let startX = 0;
    lb.addEventListener('touchstart', (e) => (startX = e.touches[0].clientX), { passive: true });
    lb.addEventListener(
      'touchend',
      (e) => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 50 && zoom === 1) go(dx < 0 ? 1 : -1); // nu naviga cât e zoom activ
      },
      { passive: true },
    );
  }
</script>
