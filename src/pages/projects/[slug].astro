---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Gallery from '../../components/Gallery.astro';
import { buildGallery } from '../../lib/gallery';
import type { ImageMetadata } from 'astro';
import { projects, type Project } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

interface Props {
  project: Project;
}
const { project } = Astro.props;

// ============================================================================
//  GALERIE PER-PROIECT
//  - Poze: fișiere din src/assets/projects/<slug>/ (optimizate automat de Astro).
//  - Video: lista `videos` din src/data/projects.ts (Vimeo / YouTube).
//  Formatul galeriei e în Gallery.astro (același folosit și de pagina BTS).
// ============================================================================
const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/projects/**/*.{jpg,jpeg,png,webp,avif}',
  { eager: true },
);

const localPhotos: { name: string; image: ImageMetadata }[] = [];
for (const [path, mod] of Object.entries(photoModules)) {
  const m = path.match(/\/projects\/([^/]+)\/([^/]+)$/);
  if (!m || m[1] !== project.slug) continue;
  localPhotos.push({ name: m[2], image: mod.default });
}

const gallery = await buildGallery({
  localPhotos,
  videos: project.videos,
  photoAlt: project.title,
  videoAlt: `${project.title} — video`,
  fallbackAlt: project.title,
});
---

<BaseLayout
  title={`${project.title} — Torjai Productions`}
  description={`${project.title} — a ${project.category.toLowerCase()} project by Torjai Productions for ${project.client}.`}
  bodyClass="bg-white text-deep-charcoal"
>
  <Gallery items={gallery}>
    <!-- Hero: back-link + logo client + subtitlu -->
    <a
      href="/projects"
      class="mb-10 inline-flex items-center gap-2 font-label-technical text-label-technical uppercase tracking-widest text-gray-500 transition-colors hover:text-black"
    >
      <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_back</span>
      All projects
    </a>

    <!-- Logo-ul firmei pentru care e făcut proiectul -->
    <div class="mb-6 flex min-h-[120px] items-center justify-center md:min-h-[150px]">
      {
        project.clientLogo ? (
          <img
            src={project.clientLogo}
            alt={`${project.client} logo`}
            class="h-[120px] w-auto object-contain md:h-[150px]"
          />
        ) : (
          <span class="font-headline-lg text-5xl uppercase leading-none tracking-tighter text-deep-charcoal md:text-7xl">
            {project.client}
          </span>
        )
      }
    </div>

    <p class="mb-8 font-label-technical text-label-technical uppercase tracking-widest text-gray-500">
      {project.title} &middot; {project.category}
    </p>
  </Gallery>
</BaseLayout>

<!--
  Cum adaugi media la acest proiect — vezi docs/GHID-CONTINUT.md:
  - Poze: pune fișierele în src/assets/projects/<slug>/ (numite 01.jpg, 02.jpg, ...).
  - Video: adaugă în src/data/projects.ts, la proiect, `videos: [{ provider, id }]`.
-->
