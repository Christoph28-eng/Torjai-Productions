---
import BaseLayout from '../layouts/BaseLayout.astro';
import Gallery from '../components/Gallery.astro';
import { galleryItemsToDisplay, type DisplayItem } from '../lib/gallery';
import { btsGallery } from '../data/btsGallery';
import { videoEmbed, videoThumb, type ProjectVideo } from '../data/projects';

// ============================================================================
//  GALERIE BTS (Behind The Scenes)
//  Media reală în public/bts/ (poze WebP + video MP4 + postere WebP), listată
//  în src/data/btsGallery.ts. Formatul galeriei e identic cu cel din interiorul
//  unui proiect (vezi Gallery.astro): click pe poză/clip → lightbox cu navigare.
// ============================================================================
// Clip BTS de la „First Day at Work" (YouTube) — pus primul în galerie.
const firstDayBts: ProjectVideo = {
  provider: 'youtube',
  id: 'omeHJcK75Vs',
  alt: 'First Day at Work — behind the scenes',
};
// Ordine după recență: fișierele cu `date` (adăugate recent) urcă în capul galeriei,
// cel mai recent primul; cele fără `date` rămân în ordinea lor (sortare stabilă).
// Așa, când adaugi media nouă în btsGallery.ts cu `date` setat, apare automat prima.
const btsByRecency = [...btsGallery].sort((a, b) => {
  if (a.date && b.date) return b.date.localeCompare(a.date);
  if (a.date) return -1;
  if (b.date) return 1;
  return 0;
});
const gallery: DisplayItem[] = [
  {
    type: 'video',
    thumb: videoThumb(firstDayBts),
    full: videoThumb(firstDayBts),
    embed: videoEmbed(firstDayBts),
    alt: firstDayBts.alt!,
  },
  ...galleryItemsToDisplay(btsByRecency, {
    photoAlt: 'Behind The Scenes — Torjai Productions',
    videoAlt: 'Behind The Scenes — video',
    muteVideos: true, // clipurile-footage BTS pornesc fără sunet (cu buton de volum)
  }),
];
---

<BaseLayout
  title="Behind The Scenes — Torjai Productions"
  description="Behind the scenes — photos and video from Torjai Productions sets and shoots."
  bodyClass="bg-white text-deep-charcoal"
>
  <Gallery items={gallery}>
    <!-- Hero: titlul paginii -->
    <div class="mb-8 flex min-h-[120px] items-center justify-center md:min-h-[150px]">
      <h1
        class="font-headline-lg text-5xl uppercase leading-none tracking-tighter text-deep-charcoal md:text-7xl"
      >
        Behind The Scenes
      </h1>
    </div>
  </Gallery>
</BaseLayout>

<!--
  Media BTS reală e în public/bts/ (poze, video, postere) și e listată în
  src/data/btsGallery.ts. Pentru a o schimba, regenerează acel fișier din
  procesarea footage-ului (vezi docs/GHID-CONTINUT.md).
-->
