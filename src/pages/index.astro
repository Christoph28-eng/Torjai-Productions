                      <span class="font-label-technical text-xs">{s.n}</span>
                    </div>
                    <div class="flex flex-col">
                      <h3 class="mb-1 font-label-button text-sm uppercase tracking-wider">{s.title}</h3>
                      <p class="font-body-md text-sm leading-relaxed text-on-primary-container">
                        {s.desc}
                      </p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
        <!-- Coloana dreaptă (imagini) -->
        <div class="relative flex justify-center md:justify-end">
          <div class="relative w-full md:h-full md:w-auto">
            <img
              alt="Torjai Productions crew on a rooftop set in Berlin"
              class="aspect-[4/5] w-full rounded-[2.5rem] object-cover shadow-xl md:h-full md:w-auto"
              src="/home/precision-big.webp"
            />
            <div class="absolute -bottom-12 -left-12 z-10 w-2/3 overflow-hidden rounded-[2rem] border-[6px] border-white shadow-2xl">
