          <div class="mb-8 h-px w-full bg-slate-200"></div>
          <p class="mb-8 max-w-xs font-body-md text-on-primary-container">
            Can't find the answer you're looking for? We're here to help.
          </p>
          <a
            href="/contact"
            class="group flex items-center gap-3 self-start rounded-full bg-deep-charcoal px-8 py-4 text-white transition-colors hover:bg-studio-grey"
          >
            <span class="font-label-button uppercase">Get in touch</span>
            <span class="material-symbols-outlined text-xl" aria-hidden="true">chat_bubble</span>
          </a>
        </div>

        <div class="flex flex-col gap-4 md:col-span-8">
          {
            faqs.map((item, i) => (
              <details
                open={i === 0}
                class="rounded-2xl border border-slate-100 bg-gray-100 p-8 shadow-sm"
              >
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-label-button text-lg text-deep-charcoal">
                  {item.q}
                  <span
                    class="material-symbols-outlined shrink-0 text-slate-400"
                    aria-hidden="true"
                  >
                    expand_more
                  </span>
                </summary>
                <p class="mt-6 font-body-md leading-relaxed text-on-primary-container">
                  {item.a}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Marquee fără flicker: drive-uim transform-ul cu requestAnimationFrame în loc de
     animația CSS. Animația CSS are un „iteration boundary" (resetul -50%) la care
     unele browsere repictează stratul mare → micro-pauză/flicker o dată pe ciclu.
     rAF e continuu (wrap manual cu o lățime de copie, conținut identic) → fără reset.
     CSS-ul rămâne ca fallback dacă JS nu rulează. Respectă prefers-reduced-motion. -->
<script>
  function setupMarquee(el, dir, copies, secondsPerCopy) {
    if (!el) return;
    const reduce = matchMedia('(prefers-reduced-motion: reduce)');
    let raf = 0, x = 0, oneCopy = 0, speed = 0, last = 0, running = false;

    function measure(initial) {
      oneCopy = el.scrollWidth / copies;
      speed = oneCopy / secondsPerCopy; // px / s
      if (initial) {
        x = dir > 0 ? -oneCopy : 0;
      } else if (oneCopy > 0) {
        // păstrează faza la resize/swap de font (fără salt vizibil)
        x = x % oneCopy;
        if (x > 0) x -= oneCopy;
      }
    }
    function frame(now) {
      if (!last) last = now;
      const dt = Math.min(0.05, (now - last) / 1000); // clamp (revenire din tab inactiv)
      last = now;
      x += dir * speed * dt;
      if (x <= -oneCopy) x += oneCopy;
      else if (x > 0) x -= oneCopy;
      el.style.transform = 'translate3d(' + x + 'px,0,0)';
      raf = requestAnimationFrame(frame);
    }
    function start() {
      if (running || reduce.matches) return;
      running = true;
      el.style.animation = 'none'; // dezactivează animația CSS, preluăm cu rAF
      measure(true);
      last = 0;
      raf = requestAnimationFrame(frame);
    }
    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    let rt;
    addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => { if (running) measure(false); }, 150);
    });
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(() => { if (running) measure(false); });
    }
    reduce.addEventListener('change', () => (reduce.matches ? stop() : start()));
    start();
  }

  // Hero „TORJAI PRODUCTIONS": 2 copii, dreapta→stânga, ~45s/copie.
  setupMarquee(document.querySelector('.animate-marquee'), -1, 2, 45);
  // Logo-uri clienți: 4 copii, stânga→dreapta, ~35s/copie (viteză ca înainte).
  setupMarquee(document.querySelector('.logo-track'), 1, 4, 35);

  // Showcase „live" din About: respectă prefers-reduced-motion (oprește videoul).
  if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('video.showcase-media').forEach((v) => {
      v.removeAttribute('autoplay');
      v.pause();
    });
  }
</script>

<!--
  TODO conținut:
  - Înlocuiește imaginile placeholder (lh3.googleusercontent.com) cu media reală Torjai.
  - Înlocuiește logo-urile de clienți cu cele reale (sau confirmă lista).
  - Textul About/FAQ e draft — adaptează-l la textul tău final.
