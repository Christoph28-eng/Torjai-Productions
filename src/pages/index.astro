---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutTorjai from '../components/home/AboutTorjai.astro';
import Testimonials from '../components/home/Testimonials.astro';

// Logo-uri REALE de client. Fiecare e o siluetă albă (PNG/SVG) în public/logos/,
// afișată dim (opacity 40%) și luminată la hover — păstrează cromatica gri→alb a
// marquee-ului. `href` = pagina de proiect deschisă la click.
// `h` = înălțimea afișată (px). NU e uniformă pe bună dreptate: logo-urile cu mai
// multe rânduri / iconiță (Berlinale, BBB, ALEX) primesc o cutie mai înaltă ca
// textul lor să fie la fel de lizibil ca un wordmark pe un rând (ex. EK Strategy).
const clients = [
  { name: 'Avanti', logo: '/logos/avanti.png', href: '/projects/avanti', h: 46 },
  { name: 'EK Strategy', logo: '/logos/ekstrategy.png', href: '/projects/ekstrategy', h: 40 },
  { name: 'Samsung', logo: '/logos/samsung.svg', href: '/projects/samsung-qfroost', h: 40 },
  { name: 'ALEX Kosmos', logo: '/logos/alex-kosmos.png', href: '/projects/tv', h: 56 },
  { name: 'Berlinale', logo: '/logos/berlinale.png', href: '/projects/berlinale', h: 72 },
  { name: 'Playground Boxing Berlin', logo: '/logos/playground.png', href: '/projects/playground', h: 34 },
  { name: 'BBB Bürgschaftsbank Berlin', logo: '/logos/bbb.png', href: '/projects/ekstrategy', h: 58 },
  { name: 'Tekirdağ Rakısı', logo: '/logos/tekirdag.png', href: '/projects/ekstrategy', h: 48 },
];

// Proces de producție (coloana stângă din secțiunea "Precision driven")
const services = [
  {
    n: '01',
    title: 'Logline',
    desc: 'You bring the idea; we sharpen the message and define the audience.',
  },
  {
    n: '02',
    title: 'Scope & Budget',
    desc: 'Deliverables, timeline, and a transparent budget agreed up front.',
  },
  {
    n: '03',
    title: 'Treatment & Script',
    desc: 'We shape the story, tone, and visual direction.',
  },
  {
    n: '04',
    title: 'Shot List',
    desc: 'Every angle planned, no guesswork on set.',
  },
  {
    n: '05',
    title: 'Storyboard',
    desc: 'A visual blueprint before a single frame is shot.',
  },
  {
    n: '06',
    title: 'Production & Post',
    desc: 'Filming, editing, color, and sound, finished at cinematic quality.',
  },
];

// FAQ
const faqs = [
  {
    q: 'What services does Torjai Productions offer?',
    a: "Think of us as one team that carries a project from first idea to finished film, creative development, direction, cinematography, editing, color, and sound, all under one roof. A small core handles the day-to-day, and a hand-picked network of directors, camera crews, editors, and designers lets us size the team to the job, from a two-person shoot to a full international production.",
  },
  {
    q: 'What kind of films do you produce?',
    a: "Our output splits roughly in half. One side is made for brands: image films, campaigns, and social-media content for clients in tech, finance, hospitality, lifestyle, automobile and beyond. The other is more personal: short films and documentaries we develop ourselves, where we experiment with form and voice. The two trade ideas constantly, and the client work is sharper for it.",
  },
  {
    q: 'Who do you work with?',
    a: "We work directly with brands across tech, finance, and the creator economy, among them Samsung, BBB Bürgschaftsbank Berlin-Brandenburg, Tekirdağ Rakısı, EKSTRATEGY, Playground Boxing Berlin, Spiky Cherry Clothing and creator Qfroost. Based in Berlin and Bucharest, we shoot wherever a project takes us.",
  },
  {
    q: 'How long does a typical production take?',
    a: "There's no fixed number, it depends on the scope of the project. A straightforward commercial can wrap in a couple of weeks; something more ambitious takes longer. Whatever the scale, the rhythm stays the same: prep, shoot, post, then a feedback round before final delivery. We're built to move fast without letting quality slip.",
  },
  {
    q: 'What sets Torjai Productions apart?',
    a: "Two things, mainly. A cinematographer's eye sits at the center of everything we make, so the work looks like film, not advertising. And because we keep the core lean and scale up only when a project needs it, we stay fast, flexible and equally at home on a single social spot or a multi-day campaign.",
  },
];
---

<BaseLayout
  title="Torjai Productions — Photo & Video, Berlin"
  description="High-end cinematography & industrial film production based in Berlin."
>
  <!-- Film grain overlay -->
  <div class="film-grain"></div>

  <!-- ===================== HERO ===================== -->
  <section
    class="relative flex h-[120vh] w-full flex-col justify-end overflow-hidden border-b border-studio-grey bg-gradient-to-t from-studio-grey to-black"
  >
    <div class="absolute top-32 z-20 w-full text-center md:top-40">
      <p class="font-label-technical text-label-technical uppercase tracking-widest text-tertiary">
        Berlin based. Available globally.
      </p>
    </div>

    <div class="relative z-10 flex w-full overflow-hidden whitespace-nowrap">
      <div class="animate-marquee">
        <h1
          class="select-none bg-gradient-to-b from-white via-tertiary-fixed-dim to-[#111111] bg-clip-text pr-8 font-display-xl text-[20rem] uppercase leading-[0.8] tracking-tighter text-transparent md:text-[44rem]"
        >
          TORJAI PRODUCTIONS
        </h1>
        <h1
          aria-hidden="true"
          class="select-none bg-gradient-to-b from-white via-tertiary-fixed-dim to-[#111111] bg-clip-text pr-8 font-display-xl text-[20rem] uppercase leading-[0.8] tracking-tighter text-transparent md:text-[44rem]"
        >
          TORJAI PRODUCTIONS
        </h1>
      </div>
    </div>

    <div class="pointer-events-none absolute inset-0 z-20 m-margin-mobile md:m-margin-desktop">
      <div class="reticle-tl"></div>
      <div class="reticle-tr"></div>
      <div class="reticle-bl"></div>
      <div class="reticle-br"></div>
    </div>

    <div
      class="absolute bottom-10 left-1/2 z-30 flex -translate-x-1/2 flex-col items-center opacity-50"
    >
      <span class="mb-2 font-label-technical text-label-technical text-on-background">SCROLL</span>
      <div class="h-16 w-px bg-gradient-to-b from-on-background to-transparent"></div>
    </div>
  </section>

  <!-- ===================== CLIENT LOGOS MARQUEE ===================== -->
  <section class="relative overflow-hidden border-b border-studio-grey bg-background py-10 md:py-12">
    {/* O singură pistă cu lista de 4× (clients × 4); keyframe-ul translateX(-50%)
        mută exact 2 copii → loop fără cusătură. 4× (nu 2×) ca o jumătate de pistă
        să fie mereu mai lată decât viewport-ul chiar și pe monitoare 1440p/ultrawide
        (altfel s-ar vedea un gol gol care derulează = „pauza"/flicker-ul de la loop).
        Spațierea = padding simetric pe fiecare item (px-…), ca șirul să fie perfect
        periodic. Doar primele `clients.length` sunt accesibile; restul = aria-hidden. */}
    <div class="logo-track animate-marquee-reverse items-center">
      {
        [...clients, ...clients, ...clients, ...clients].map((c, i) => {
          const dup = i >= clients.length;
          return (
            <a
              href={c.href}
              class="group flex shrink-0 items-center px-6 sm:px-8 md:px-10"
              aria-label={dup ? undefined : `${c.name} — open project`}
              aria-hidden={dup ? 'true' : undefined}
              tabindex={dup ? -1 : undefined}
            >
              <img
                src={c.logo}
                alt={dup ? '' : `${c.name} logo`}
                draggable={false}
                style={`--logo-h:${c.h}px`}
                class="marquee-logo w-auto max-w-none select-none opacity-40 transition-all duration-300 group-hover:opacity-100"
              />
            </a>
          );
        })
      }
    </div>
  </section>

