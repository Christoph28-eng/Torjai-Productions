          <img src="/home/about/berlinale-2.webp" alt="" class="showcase-media berl-slide" />
          <img src="/home/about/berlinale-3.webp" alt="" class="showcase-media berl-slide" />
          <img src="/home/about/berlinale-4.webp" alt="" class="showcase-media berl-slide" />
          <img src="/home/about/berlinale-5.webp" alt="" class="showcase-media berl-slide" />
          <img src="/home/about/berlinale-6.webp" alt="" class="showcase-media berl-slide" />
