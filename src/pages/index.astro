            FORGED
          </div>
          <div class="font-headline-lg text-[3.25rem] uppercase leading-none tracking-tighter text-tertiary md:text-[12rem] md:text-surface-variant">
            IN BERLIN.
          </div>
        </div>
        <div class="relative mt-[-1rem] flex items-baseline md:mt-[-4rem]">
          <div class="z-0 font-headline-lg text-[4rem] uppercase leading-none tracking-tighter text-surface-tint opacity-50 md:text-[16rem]">
            MADE
          </div>
          <div class="absolute left-[5%] top-[1.5rem] z-10 flex items-baseline gap-3 md:left-[25%] md:top-[4rem] md:gap-4">
            <div class="font-headline-lg text-[2.75rem] uppercase leading-none tracking-tighter text-tertiary md:text-[10rem] md:text-surface-variant">
              FOR
            </div>
            <div class="font-headline-lg text-[3.25rem] uppercase leading-none tracking-tighter text-white md:text-[13rem]">
              CINEMA.
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="relative z-20 mx-auto max-w-container-max px-margin-mobile md:px-margin-desktop">
      <div class="mt-20 flex flex-col items-end justify-start gap-6 md:flex-row md:gap-8">
        {/* 3 carduri „live", fiecare cu media în loop din proiectul real; tot cardul
