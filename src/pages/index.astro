          href="/projects/samsung-qfroost"
          aria-label="Samsung × Qfroost — open project"
          class="group relative mt-20 block h-[500px] w-full shrink-0 overflow-hidden rounded-[2rem] shadow-2xl md:mt-0 md:w-[300px]"
